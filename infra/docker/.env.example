# NOTARIST RAG PLATFORM — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ─── Gradle / Nexus Repository ───────────────
# Required for Gradle to resolve dependencies from the internal Nexus registry.
# (build.gradle.kts: System.getenv("NEXUS_URL") with mavenCentral() as fallback)
NEXUS_URL=https://nexus.notarist.internal/repository/maven-public/
NEXUS_USER=your-nexus-username
NEXUS_PASSWORD=your-nexus-password

# ─── Spring ──────────────────────────────────
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true

# ─── Security / JWT ──────────────────────────
# TTLs are in SECONDS (bound to notarist.auth.jwt.*). 900s = 15m, 604800s = 7d.
JWT_ISSUER=notarist-rag
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
JWT_PRIVATE_KEY_PATH=file:./keys/notarist-private.pem
JWT_PUBLIC_KEY_PATH=file:./keys/notarist-public.pem
APP_ENCRYPTION_KEY=change-me-32-char-aes-key-here!!
APP_ENCRYPTION_SALT=change-me-16-byte-salt!!

# ─── Database migrations (SECURITY-CRITICAL) ─
# Flyway is now owned programmatically by FlywaySearchConfig, which ALWAYS migrates on startup
# against the single PostgreSQL database. There is no longer a LIQUIBASE_ENABLED / FLYWAY_ENABLED
# pair to get wrong: the tenant-isolation RLS policies (V9) and the audit_trail / token_deny_list
# tables (V7) are applied by construction, so a fresh database can no longer boot into the state
# where the database-level tenant backstop silently does not exist.

# ─── PostgreSQL (Supabase in production) ─────
# The one and only database: JPA (notarist_user, dokumen_legal, ingestion_job) and every
# JdbcTemplate path (chunk_index, audit_trail, session_token, ingestion_queue) share it.
#
# The application role must NOT be a superuser and must NOT have BYPASSRLS: both ignore row-level
# security outright, which would silently disable the cross-tenant isolation policies in Flyway V9.
#
# For Supabase, POSTGRES_URL is the connection string from Project Settings → Database, e.g.
#   jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# From Cloud Run, prefer the transaction pooler (port 6543) and keep
# POSTGRES_POOL_MAX * max-instances under the project's connection ceiling.
POSTGRES_DB=notarist
POSTGRES_USER=notarist_app
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432
POSTGRES_URL=jdbc:postgresql://localhost:5432/notarist
POSTGRES_POOL_MAX=10

# ─── Qdrant ──────────────────────────────────
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=notarist_chunks

# ─── Google Cloud Storage (object storage) ───
# Replaces MinIO. Auth is Application Default Credentials — no endpoint, no access/secret key.
#   • Cloud Run: the attached runtime service account (Workload Identity). Leave
#     GCS_CREDENTIALS_PATH empty and set GCS_SIGNING_SERVICE_ACCOUNT to the runtime SA so V4
#     signed upload URLs are minted via IAM signBlob with no private key on the instance.
#   • Local/CI: set GCS_CREDENTIALS_PATH to a service-account key file (or set
#     GOOGLE_APPLICATION_CREDENTIALS), or run `gcloud auth application-default login`.
# GCS_BUCKET is REQUIRED (no default): GCS bucket names are globally unique.
GCS_BUCKET=notarist-documents
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCS_CREDENTIALS_PATH=
GCS_SIGNING_SERVICE_ACCOUNT=
# Region used only when GCS_AUTO_CREATE_BUCKET=true (keep false in prod; provision via Terraform).
GCS_LOCATION=US
GCS_AUTO_CREATE_BUCKET=false
# Signed upload URL lifetime, seconds (bound to notarist.ingest.signed-url-ttl-seconds).
INGEST_SIGNED_URL_TTL_SECONDS=3600

# ─── Ollama (local LLM) ──────────────────────
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=notarist-llm-7b
OLLAMA_TIMEOUT_MS=120000

# ─── AI Sidecar Services ─────────────────────
OCR_BASE_URL=http://localhost:8081
OCR_TIMEOUT_MS=120000
NER_BASE_URL=http://localhost:8082
NER_TIMEOUT_MS=30000
RERANKER_BASE_URL=http://localhost:8083
RERANKER_TIMEOUT_MS=15000

# ─── Ingestion Queue ─────────────────────────
QUEUE_POLL_INTERVAL_MS=2000
QUEUE_MAX_CONCURRENT_WORKERS=3
QUEUE_LOCK_TIMEOUT_MS=300000
QUEUE_MAX_RETRY_ATTEMPTS=3
