# Copy to backend/.env.supabase (gitignored) and fill in the REAL Supabase values.
# I will `set -a; source backend/.env.supabase; set +a` before `./gradlew bootRun`.
# Do NOT commit the filled-in file. Placeholders only in this .example.

# ── Supabase PostgreSQL (REQUIRED — from you) ─────────────────────────────────
# Use the DIRECT connection (port 5432) or the SESSION pooler — NOT the transaction
# pooler (6543), which breaks Flyway advisory locks and JPA prepared statements.
# sslmode=require is mandatory for Supabase.
export POSTGRES_URL="jdbc:postgresql://db.<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require"
export POSTGRES_USER="postgres"
export POSTGRES_PASSWORD="<YOUR-SUPABASE-DB-PASSWORD>"

# ── Boot secrets (dev values are fine for an empty DB — override if you have real ones) ──
export APP_ENCRYPTION_KEY="<32+ char dev key>"
export APP_ENCRYPTION_SALT="<16 char dev salt>"

# ── GCS (bucket NAME only — no credentials needed now; the Storage client is @Lazy) ──
export GCS_BUCKET="notarist-dev"

# ── JWT keys (dev RSA pair; I generate these and set the paths for you) ──
# export JWT_PRIVATE_KEY_PATH="./keys/notarist-private.pem"
# export JWT_PUBLIC_KEY_PATH="./keys/notarist-public.pem"
