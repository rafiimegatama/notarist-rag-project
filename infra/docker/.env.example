# NOTARIST RAG PLATFORM — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ─── MinIO ───────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── PostgreSQL ──────────────────────────────
POSTGRES_DB=notarist_search
POSTGRES_USER=notarist
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# ─── Qdrant ──────────────────────────────────
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
# QDRANT_API_KEY=  # leave blank for local dev (no auth)

# ─── Ollama ──────────────────────────────────
OLLAMA_PORT=11434

# ─── Oracle 19C (external — not in compose) ──
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SID=NOTARIST
ORACLE_USER=notarist_app
ORACLE_PASSWORD=change-me-in-production
ORACLE_VPD_CONTEXT_NAMESPACE=NOTARIST_CTX

# ─── Spring Application ───────────────────────
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# ─── MinIO Spring Config ──────────────────────
SPRING_MINIO_ENDPOINT=http://localhost:9000
SPRING_MINIO_ACCESS_KEY=minioadmin
SPRING_MINIO_SECRET_KEY=change-me-in-production
SPRING_MINIO_DEFAULT_BUCKET=notarist-documents

# ─── Qdrant Spring Config ─────────────────────
SPRING_QDRANT_HOST=localhost
SPRING_QDRANT_PORT=6333
SPRING_QDRANT_COLLECTION_NAME=notarist-chunks

# ─── PostgreSQL Spring Config ─────────────────
SPRING_DATASOURCE_POSTGRES_URL=jdbc:postgresql://localhost:5432/notarist_search
SPRING_DATASOURCE_POSTGRES_USERNAME=notarist
SPRING_DATASOURCE_POSTGRES_PASSWORD=change-me-in-production
