{
  "expo": {
    "name": "Notarist RAG",
    "slug": "notarist-rag",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.notarist.ragapp"
    },
    "android": {
      "package": "com.notarist.ragapp",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8FAFC",
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0F172A",
            "image": "./assets/splash-icon.png"
          }
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}
