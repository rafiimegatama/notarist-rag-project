# NOTARIST RAG PLATFORM — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ─── Gradle / Nexus Repository ───────────────
# Required for Gradle to resolve dependencies from the internal Nexus registry.
# (build.gradle.kts: System.getenv("NEXUS_URL") with mavenCentral() as fallback)
NEXUS_URL=https://nexus.notarist.internal/repository/maven-public/
NEXUS_USER=your-nexus-username
NEXUS_PASSWORD=your-nexus-password

# ─── Spring ──────────────────────────────────
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true

# ─── Security / JWT ──────────────────────────
# TTLs are in SECONDS (bound to notarist.auth.jwt.*). 900s = 15m, 604800s = 7d.
JWT_ISSUER=notarist-rag
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
JWT_PRIVATE_KEY_PATH=file:./keys/notarist-private.pem
JWT_PUBLIC_KEY_PATH=file:./keys/notarist-public.pem
APP_ENCRYPTION_KEY=change-me-32-char-aes-key-here!!
APP_ENCRYPTION_SALT=change-me-16-byte-salt!!

# ─── Oracle 19C (external — not in compose) ──
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SID=NOTARIST
ORACLE_URL=jdbc:oracle:thin:@localhost:1521/NOTARISTDB
ORACLE_USER=notarist_app
ORACLE_PASSWORD=change-me-in-production
ORACLE_POOL_MAX=10
ORACLE_POOL_MIN=2
ORACLE_VPD_CONTEXT_NAMESPACE=NOTARIST_CTX

# ─── PostgreSQL ──────────────────────────────
POSTGRES_DB=notarist_search
POSTGRES_USER=notarist_app
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432
POSTGRES_URL=jdbc:postgresql://localhost:5432/notarist_search
POSTGRES_POOL_MAX=10

# ─── Qdrant ──────────────────────────────────
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=notarist_chunks

# ─── MinIO ───────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production
# Note: docker-compose.yml defaults MINIO_ROOT_PASSWORD to "change-me-in-production" if unset.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-in-production
MINIO_UPLOAD_URL_TTL_MINUTES=15
MINIO_BUCKET_RAW=notarist-raw
MINIO_BUCKET_OCR=notarist-ocr
MINIO_BUCKET_PROCESSED=notarist-processed
MINIO_BUCKET_CHUNK=notarist-chunk
MINIO_BUCKET_EXPORT=notarist-export

# ─── Ollama (local LLM) ──────────────────────
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=notarist-llm-7b
OLLAMA_TIMEOUT_MS=120000

# ─── AI Sidecar Services ─────────────────────
OCR_BASE_URL=http://localhost:8081
OCR_TIMEOUT_MS=120000
NER_BASE_URL=http://localhost:8082
NER_TIMEOUT_MS=30000
RERANKER_BASE_URL=http://localhost:8083
RERANKER_TIMEOUT_MS=15000

# ─── Ingestion Queue ─────────────────────────
QUEUE_POLL_INTERVAL_MS=2000
QUEUE_MAX_CONCURRENT_WORKERS=3
QUEUE_LOCK_TIMEOUT_MS=300000
QUEUE_MAX_RETRY_ATTEMPTS=3
