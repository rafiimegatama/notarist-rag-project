# HYBRID boot environment — fill in REAL values, then:
#   docker compose up -d                 # sidecar stack first (OCR/NER/embed/Qdrant/Ollama)
#   docker compose -f docker-compose.hybrid.yml --env-file .env.hybrid up --build
#
# On first boot the dev profile creates a demo login automatically (no manual SQL):
#   demo.notaris / NotaristDemo123!   (override via DEV_SEED_USERNAME / DEV_SEED_PASSWORD)
#
# Nothing here is a mock. POSTGRES_URL must be a real Supabase instance; the
# service-account key must grant roles/storage.objectAdmin on the real bucket.

# ---- REAL Supabase PostgreSQL --------------------------------------------------
# Use the SESSION pooler (:5432), NOT the direct host and NOT the transaction pooler:
#   - db.<ref>.supabase.co publishes only an AAAA record (IPv6-only) — unroutable from
#     most dev machines ("Name does not resolve", then an endless Hikari retry loop)
#   - the transaction pooler (:6543) breaks Flyway advisory locks and JPA prepared statements
# The pooler identifies the tenant by the username suffix: <role>.<project-ref>.
# The role MUST NOT be a superuser and MUST NOT hold BYPASSRLS, or RLS tenant
# isolation is silently voided.
POSTGRES_URL=jdbc:postgresql://aws-1-CHANGEME-region.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_USER=notarist_app.CHANGEME-project-ref
POSTGRES_PASSWORD=CHANGEME
# Supabase's session pooler caps clients at pool_size (15 by default). The app runs THREE
# Hikari pools: primary (POSTGRES_POOL_MAX) + ingest (POSTGRES_POOL_MAX) + audit (2).
# 5+5+2=12 stays under the cap with headroom for psql/tools; 8 would allow 8+8+2=18 > 15.
POSTGRES_POOL_MAX=5

# ---- REAL Google Cloud Storage -------------------------------------------------
GCS_BUCKET=CHANGEME-notarist-documents          # a bucket that ALREADY exists
GOOGLE_CLOUD_PROJECT=CHANGEME-project-id
GCS_CREDENTIALS_PATH=./secrets/gcs-key.json     # host path to a real SA key JSON
# (an `authorized_user` ADC JSON copied from ~/.config/gcloud/application_default_credentials.json
#  also works for boot + object I/O; V4 signed URLs additionally need a service account)
# REQUIRED for document upload (POST /ingest returns a V4 signed PUT URL; signing fails
# without it: "Signing key was not provided"). The ADC principal needs
# roles/iam.serviceAccountTokenCreator on this SA, and the SA needs storage.objectAdmin
# on the bucket. Auth + search + assistant work without it.
GCS_SIGNING_SERVICE_ACCOUNT=CHANGEME-sa@CHANGEME-project-id.iam.gserviceaccount.com

# ---- JWT RS256 keys ------------------------------------------------------------
# Host directory containing private.pem and public.pem. Generate throwaway keys with:
#   mkdir -p secrets/keys && \
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out secrets/keys/private.pem && \
#   openssl rsa -in secrets/keys/private.pem -pubout -out secrets/keys/public.pem && \
#   chmod 0644 secrets/keys/private.pem
# NOTE: the image runs as non-root uid 999 (notarist). A private key mounted at 0600/host-uid
# is UNREADABLE inside the container (java.nio.file.AccessDeniedException at JwtService startup),
# so make the mounted key world-readable (0644). In production the key comes from a Secret Manager
# volume mount, which is already readable by the runtime SA — this only applies to local file mounts.
JWT_KEYS_DIR=./secrets/keys

# ---- App ----
APP_PORT=8080
