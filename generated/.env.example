# ─────────────────────────────────────────────────────────────────
# .env.example — NOTARIST RAG PLATFORM
#
# Copy to .env and fill values before running the application.
# NEVER commit .env to version control.
# This file is safe to commit — it contains only placeholder values.
#
# Requirement key:
#   [REQUIRED] — Application fails to start without this value
#   [REQUIRED_PROD] — Required in staging/prod; has safe local default
#   [OPTIONAL] — Has a reasonable default; override if needed
# ─────────────────────────────────────────────────────────────────

# ── Spring Profile ──────────────────────────────────────────────
# [OPTIONAL] Values: local | dev | staging | prod
SPRING_PROFILES_ACTIVE=local

# ── Application Encryption ──────────────────────────────────────
# [REQUIRED] AES-256 key for field-level encryption (base64, 32 bytes)
APP_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key

# [REQUIRED] Encryption salt (base64)
APP_ENCRYPTION_SALT=replace-with-base64-encoded-salt

# ── JWT ─────────────────────────────────────────────────────────
# [OPTIONAL] Default: notarist-rag
JWT_ISSUER=notarist-rag

# [OPTIONAL] Default: 15 (minutes)
JWT_ACCESS_TOKEN_TTL_MINUTES=15

# [OPTIONAL] Default: 7 (days)
JWT_REFRESH_TOKEN_TTL_DAYS=7

# [REQUIRED_PROD] RSA private key path (PEM). Default: file:./keys/notarist-private.pem
JWT_PRIVATE_KEY_PATH=file:./keys/notarist-private.pem

# [REQUIRED_PROD] RSA public key path (PEM). Default: file:./keys/notarist-public.pem
JWT_PUBLIC_KEY_PATH=file:./keys/notarist-public.pem

# ── Oracle Database ─────────────────────────────────────────────
# [OPTIONAL] Default: jdbc:oracle:thin:@localhost:1521/NOTARISTDB
ORACLE_URL=jdbc:oracle:thin:@localhost:1521/NOTARISTDB

# [OPTIONAL] Default: notarist_app
ORACLE_USER=notarist_app

# [REQUIRED] No default — application fails to start if not set
ORACLE_PASSWORD=replace-with-oracle-password

# [OPTIONAL] Default: 20
ORACLE_POOL_MAX=20

# [OPTIONAL] Default: 5
ORACLE_POOL_MIN=5

# ── PostgreSQL ──────────────────────────────────────────────────
# [OPTIONAL] Default: jdbc:postgresql://localhost:5432/notarist
POSTGRES_URL=jdbc:postgresql://localhost:5432/notarist

# [OPTIONAL] Default: notarist_app
POSTGRES_USER=notarist_app

# [REQUIRED] No default — application fails to start if not set
POSTGRES_PASSWORD=replace-with-postgres-password

# [OPTIONAL] Default: 10
POSTGRES_POOL_MAX=10

# ── MinIO ────────────────────────────────────────────────────────
# [OPTIONAL] Default: http://localhost:9000
MINIO_ENDPOINT=http://localhost:9000

# [REQUIRED] No default — application fails to start if not set
MINIO_ACCESS_KEY=replace-with-minio-access-key

# [REQUIRED] No default — application fails to start if not set
MINIO_SECRET_KEY=replace-with-minio-secret-key

# ── Qdrant ───────────────────────────────────────────────────────
# [OPTIONAL] Default: localhost
QDRANT_HOST=localhost

# [OPTIONAL] Default: 6333
QDRANT_PORT=6333

# [OPTIONAL] Default: empty (no auth). Strongly recommended in staging/prod.
QDRANT_API_KEY=

# ── AI Runtime ───────────────────────────────────────────────────
# [OPTIONAL] Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# [OPTIONAL] Default: notarist-llm-7b
OLLAMA_MODEL=notarist-llm-7b

# [OPTIONAL] Default: 60000 (ms). SSE emitter timeout is OLLAMA_INFERENCE_TIMEOUT_MS + 30000.
OLLAMA_INFERENCE_TIMEOUT_MS=60000

# [OPTIONAL] Default: http://localhost:8081
OCR_BASE_URL=http://localhost:8081

# [OPTIONAL] Default: http://localhost:8084
EMBEDDING_BASE_URL=http://localhost:8084

# [OPTIONAL] Default: http://localhost:8083
RERANKER_BASE_URL=http://localhost:8083

# [OPTIONAL] Default: http://localhost:8082
NER_BASE_URL=http://localhost:8082

# ── Observability ────────────────────────────────────────────────
# [OPTIONAL] Default: true
PROMETHEUS_ENABLED=true

# [OPTIONAL] Default: INFO
LOG_LEVEL=INFO
